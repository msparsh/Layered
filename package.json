{
    "name": "notebook",
    "version": "1.0.0",
    "description": "Minimal Interactive Notebook",
    "main": "main_electron.js",
    "scripts": {
        "dev": "vite",
        "build:vite": "vite build",
        "start": "npm run build:vite && electron .",
        "build": "npm run build:vite && electron-builder" 
    },
    "author": "",
    "license": "MIT",
    "devDependencies": {
        "@sveltejs/vite-plugin-svelte": "^7.1.2",
        "electron": "^41.2.0",
        "electron-builder": "^26.8.1",
        "svelte": "^5.55.7",
        "vite": "^8.0.13"
    },
    "build": {
        "appId": "com.notebook.app",
        "productName": "Notebook",
        "directories": {
            "output": "release" 
        },
        "files": [
            "dist/**/*",
            "main_electron.js"
        ],
        "win": {
            "target": "nsis"
        }
    }
}